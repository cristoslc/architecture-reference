{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Review Response",
  "description": "Response schema for architecture classification LLM review",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "verdict": { "const": "classified" },
        "styles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Microservices",
              "Event-Driven",
              "Modular Monolith",
              "Domain-Driven Design",
              "Hexagonal Architecture",
              "CQRS",
              "Serverless",
              "Layered",
              "Service-Based",
              "Space-Based",
              "Pipe-and-Filter",
              "Multi-Agent"
            ]
          },
          "minItems": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "summary": { "type": "string", "minLength": 10 },
        "notes": { "type": "string", "minLength": 10 },
        "entry_type": {
          "type": "string",
          "enum": ["repo", "ecosystem"],
          "default": "repo"
        }
      },
      "required": ["verdict", "styles", "confidence", "summary", "notes"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "verdict": { "const": "needs_info" },
        "requests": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "type": { "const": "file" },
                  "path": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "required": ["type", "path", "reason"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": { "const": "tree" },
                  "path": { "type": "string" },
                  "depth": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "reason": { "type": "string" }
                },
                "required": ["type", "path", "reason"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": { "const": "glob" },
                  "pattern": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "required": ["type", "pattern", "reason"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": { "const": "grep" },
                  "pattern": { "type": "string" },
                  "path": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "required": ["type", "pattern", "reason"],
                "additionalProperties": false
              }
            ]
          },
          "minItems": 1,
          "maxItems": 5
        }
      },
      "required": ["verdict", "requests"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "verdict": { "const": "unclassifiable" },
        "reason": { "type": "string", "minLength": 10 },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "notes": { "type": "string" }
      },
      "required": ["verdict", "reason", "confidence"],
      "additionalProperties": false
    }
  ]
}
