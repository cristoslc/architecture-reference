# Binary media files (transcripts preserved as .md files)
*.mp4
*.m4a
*.mp3
*.wav
*.avi
*.mov
*.mkv
*.webm
*.ogg
*.flac
*.aac

# Binary document files (converted to .md + images)
*.pdf
*.pptx
*.vsdx
*.xlsx
*.docx
*.drawio

# Cloned repos from research agents (not part of evidence pool)
jellyfin/
jellyfin-repo/
nopCommerce/

# Installed skills (vendored by npx @anthropic-ai/claude-code-skills)
.agents/skills/*
!.agents/skills/.gitkeep

# Skill reference data (populated at runtime, not checked in)
skills/*/references/
# Exceptions: these skills own their reference data as source-of-truth
!skills/discover-architecture/references/
!skills/compare-architecture/references/
!skills/architecture-advisor/references/

# Scratch files from LLM review context gathering
pipeline/review-context/

# Dolt database files (added by bd init)
.dolt/
*.db

# Agent spec watch log
.agents/specwatch.log

# macOS
.DS_Store

# Secrets
.env
.clone-cache/
